# ============================================================
# BELLA VITA — Environment Variables
# Copy to .env.local and fill in. Everything runs in demo mode
# WITHOUT these keys; add them to go fully live.
# ============================================================

# --- MongoDB (bookings, messages, CMS content) ---
# Get a free cluster at https://www.mongodb.com/atlas
MONGODB_URI=

# --- Google Gemini (AI chatbot) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Point the chat widget at the separately-deployed Render chatbot service.
# Leave blank to use the built-in /api/chat route (works on Vercel too).
NEXT_PUBLIC_CHATBOT_URL=

# --- EmailJS (owner notifications for bookings & enquiries) ---
# Create templates at https://www.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_TEMPLATE_BOOKING=
NEXT_PUBLIC_EMAILJS_TEMPLATE_CONTACT=

# --- Admin dashboard ---
# Password for /admin login (default: bellavita)
ADMIN_PASSWORD=bellavita
